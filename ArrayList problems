8. Display all elements using: for loop, enhanced for loop, iterator

import java.util.*;
public class Main 
{
    public static void main(String[] args)
    {
        ArrayList<String> strs = new ArrayList<>();
        strs.add("I");
        strs.add("am");
        strs.add("programming");
        strs.add("in Java");

        //using for loop
        for(int i=0;i<strs.size();i++)
        {
            System.out.print(strs.get(i)+" ");
        }
        System.out.println();
        
        //using for-each loop
        for(String s : strs)
        {
            System.out.print(s+" ");
        }
        System.out.println();
        
        //using iterator
        Iterator<String> o = strs.iterator();

        while(o.hasNext())
        {
            System.out.print(o.next()+" ");
        }
        System.out.println();

        //forEach() with lambda
        strs.forEach(x->System.out.print(x+" "));
        System.out.println();
    }
}



9. Reverse an ArrayList

import java.util.*;
import java.lang.String;
public class Main 
{
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);
        ArrayList<String> al = new ArrayList<>();
        al.add("abc");
        al.add("def");
        al.add("ghi");
        al.add("jkl");

        System.out.println(al);
        
        ArrayList<String> rev = new ArrayList<>();

        for(int i = (al.size())-1;i>=0;i--)
        {
            String x = al.get(i);
            rev.add(x);
        }
        System.out.println(rev);
    }
}


